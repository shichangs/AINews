  <dict>
    <key>Label</key>
    <string>com.ainews.sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>node</string>
      <string>/Users/sc-claw/Desktop/Github/ai-news/scripts/auto-sync-and-publish.js</string>
    </array>

    <key>WorkingDirectory</key>
