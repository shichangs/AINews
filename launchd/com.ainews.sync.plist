<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.ainews.sync</string>

    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>node</string>
      <string>/Users/sc-claw/Desktop/Github/ai-news/scripts/auto-sync-and-publish.js</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/sc-claw/Desktop/Github/ai-news</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>/Users/sc-claw</string>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
      <key>GIT_TERMINAL_PROMPT</key>
      <string>0</string>
      <key>AI_NEWS_DAILY_DIR</key>
      <string>/Users/sc-claw/Desktop/ClaudeCode/daily-ai-news</string>
      <key>AI_NEWS_WEEKLY_DIR</key>
      <string>/Users/sc-claw/Desktop/ClaudeCode/daily-ai-news/weekly</string>
      <key>AI_NEWS_PORTFOLIO_DIR</key>
      <string>/Users/sc-claw/Desktop/ClaudeCode/portfolio-news</string>
      <key>AI_NEWS_TECH_DIR</key>
      <string>/Users/sc-claw/Desktop/ClaudeCode/weekly-ai-tech</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <!-- Fallback poll every hour. Most runs are triggered by WatchPaths below;
         this catches anything WatchPaths might miss (e.g. file events during sleep). -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- Trigger immediately when external source markdown changes.
         launchd watches stat metadata (mtime/size/inode), so any add/edit fires the job. -->
    <key>WatchPaths</key>
    <array>
      <string>/Users/sc-claw/Desktop/ClaudeCode/daily-ai-news</string>
      <string>/Users/sc-claw/Desktop/ClaudeCode/daily-ai-news/weekly</string>
      <string>/Users/sc-claw/Desktop/ClaudeCode/portfolio-news</string>
      <string>/Users/sc-claw/Desktop/ClaudeCode/weekly-ai-tech</string>
    </array>

    <!-- Coalesce bursts of file events; minimum spacing between back-to-back runs. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/tmp/ai-news-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/ai-news-sync.error.log</string>
  </dict>
</plist>
